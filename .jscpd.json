{
    "threshold": 3,
    "minLines": 8,
    "minTokens": 70,
    "path": ["app", "resources/views", "resources/js", "resources/css", "routes", "database", "config"],
    "format": ["php", "javascript", "markup", "css"],
    "ignore": [
        "**/node_modules/**",
        "**/vendor/**",
        "**/database/migrations/**",
        "resources/views/flux/**",
        "config/**"
    ],
    "reporters": ["consoleFull", "json"],
    "output": "reports/jscpd",
    "gitignore": true,
    "absolute": false
}
